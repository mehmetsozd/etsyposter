# Photoshop config (her makinede .env.local içinde override edilebilir)

# macOS: Adobe Photoshop'un uygulama adı ("Applications" altındaki bundle adı).
PHOTOSHOP_APP_NAME="Adobe Photoshop 2026"

# Windows: Photoshop.exe'nin tam yolu. Boş bırakılırsa şu konumlarda otomatik
# aranır: C:\Program Files\Adobe\Adobe Photoshop {2026|2025|2024|2023|CC 2024}\
# Photoshop.exe. Farklı sürüm/konum varsa burada belirt.
PHOTOSHOP_APP_PATH=""

PHOTOSHOP_ACTION_SET="EtsyAutomation"

# Upscale action — Photoshop'ta bu isimle bir action olmalı.
PHOTOSHOP_UPSCALE_ACTION="Upscale"

# (İleri seviye) Orientation'a göre farklı action isteyenler için override.
# Boş bırakılırsa yukarıdaki PHOTOSHOP_UPSCALE_ACTION kullanılır.
PHOTOSHOP_UPSCALE_ACTION_VERTICAL=""
PHOTOSHOP_UPSCALE_ACTION_HORIZONTAL=""
PHOTOSHOP_UPSCALE_ACTION_SQUARE=""

# Video mockup PSD'lerinin bulunduğu klasör (proje root'una göre veya absolute path).
# İçinde şu isimde PSD'ler olmalı:
#   single-vertical.psd, single-horizontal.psd, single-square.psd
#   duo-vertical.psd,    duo-horizontal.psd,    duo-square.psd
#   trio-vertical.psd,   trio-horizontal.psd,   trio-square.psd
VIDEO_MOCKUPS_DIR="video_mockups"

# Photoshop'taki SAVE_VIDEO action'ı kaydederken video'yu yazdığı temp klasör.
# Action'ı kaydederken Photoshop'tan tam olarak bu klasörü seç.
PHOTOSHOP_VIDEO_TEMP_DIR="data/video-temp"

# Video action set & name. Set boşsa PHOTOSHOP_ACTION_SET kullanılır.
PHOTOSHOP_VIDEO_ACTION_SET=""
PHOTOSHOP_VIDEO_ACTION="SAVE_VIDEO"

# ── Etsy Open API v3 ──────────────────────────────────────────────────────
# Etsy Developer Portal'dan (https://www.etsy.com/developers/your-apps) alınan
# uygulama bilgileri. KEYSTRING = client_id, SHARED_SECRET asla client tarafında
# kullanılmaz (sadece bazı endpoint'ler için gerekir, OAuth PKCE'de gerekmez).
ETSY_KEYSTRING=""
ETSY_SHARED_SECRET=""

# OAuth callback URL — Etsy uygulamasında "Callback URL" alanına TAM olarak
# eklenmiş olmalı. Birden çok ortamda çalıştıracaksan hepsini ekle.
ETSY_REDIRECT_URI="http://localhost:3000/etsy/oauth2callback"

# Shop ve ilgili profil ID'leri — /etsy/bootstrap sayfasından OAuth bağladıktan
# sonra listelenir, oradan kopyalanır.
ETSY_SHOP_ID=""
ETSY_SHIPPING_PROFILE_ID=""
ETSY_RETURN_POLICY_ID=""
ETSY_READINESS_STATE_ID=""

# Sabit listing özellikleri
ETSY_TAXONOMY_ID="1029"
ETSY_DEFAULT_QUANTITY="999"
ETSY_MATERIALS="Premium Matte Paper,Semi Glossy Paper,Fine Art Paper,Museum Quality Paper,Archival Ink,Giclee Print,High Quality Paper"

