# Photoshop config (her makinede .env.local içinde override edilebilir)
PHOTOSHOP_APP_NAME="Adobe Photoshop 2026"
PHOTOSHOP_ACTION_SET="EtsyAutomation"

# Upscale action — Photoshop'ta bu isimle bir action olmalı.
PHOTOSHOP_UPSCALE_ACTION="Upscale"

# (İleri seviye) Orientation'a göre farklı action isteyenler için override.
# Boş bırakılırsa yukarıdaki PHOTOSHOP_UPSCALE_ACTION kullanılır.
PHOTOSHOP_UPSCALE_ACTION_VERTICAL=""
PHOTOSHOP_UPSCALE_ACTION_HORIZONTAL=""
PHOTOSHOP_UPSCALE_ACTION_SQUARE=""
