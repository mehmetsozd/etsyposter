# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# project workspace (uploaded + generated files)
/public/workspace/

# Etsy listing'lere eklenen sabit görseller (kullanıcıya özel asset'ler)
/public/etsy-static-mockups/

# mockup templates index + Etsy tokens (machine-specific, sensitive)
/data/

# video mockup PSDs (paid assets, machine-specific paths)
/video_mockups/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
